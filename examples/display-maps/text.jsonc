{
  // Old "text" style: show remaining account quota as plain percentages.
  "limits": {
    // Compact Limits label windows. Use ["primary"] to hide weekly from the short label.
    "summary": ["primary", "secondary"],
    "primary": "five_hour_percent",
    "secondary": "weekly_percent",
  },
  "maps": {
    "percent": {
      "kind": "template",
      "template": "{value}%",
      "unavailable": "--",
    },
    "five_hour_percent": {
      "kind": "template",
      "template": "5h {value}%",
      "unavailable": "5h --",
    },
    "weekly_percent": {
      "kind": "template",
      "template": "wk {value}%",
      "unavailable": "wk --",
    },
  },
}
