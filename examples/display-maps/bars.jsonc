{
  // Old "bars" style for the primary 5-hour limit:
  // 0% -> empty, 1..20% -> one filled cell, ..., 81..100% -> full.
  "limits": {
    // Compact Limits label windows. Use ["primary"] to hide weekly from the short label.
    "summary": ["primary", "secondary"],
    "primary": "five_hour_bars",
    "secondary": "weekly_percent",
  },
  "maps": {
    "percent": {
      "kind": "template",
      "template": "{value}%",
      "unavailable": "--",
    },
    "five_hour_bars": {
      "kind": "thresholds",
      "values": [
        { "min": 0, "label": "▱▱▱▱▱" },
        { "min": 1, "label": "▰▱▱▱▱" },
        { "min": 21, "label": "▰▰▱▱▱" },
        { "min": 41, "label": "▰▰▰▱▱" },
        { "min": 61, "label": "▰▰▰▰▱" },
        { "min": 81, "label": "▰▰▰▰▰" },
      ],
      "unavailable": "▱▱▱▱▱",
    },
    "weekly_percent": {
      "kind": "template",
      "template": "wk {value}%",
      "unavailable": "wk --",
    },
  },
}
